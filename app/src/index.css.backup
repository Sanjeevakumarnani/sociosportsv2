@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Montserrat:wght@600;700;800;900&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    /* Theme 1: Deep Navy (Default) */
    --background: 220 30% 5%;
    --foreground: 0 0% 100%;
    --card: 220 25% 10%;
    --card-foreground: 0 0% 100%;
    --popover: 220 25% 10%;
    --popover-foreground: 0 0% 100%;
    --primary: 11 100% 59%;
    --primary-foreground: 0 0% 100%;
    --secondary: 220 20% 15%;
    --secondary-foreground: 0 0% 100%;
    --muted: 220 15% 20%;
    --muted-foreground: 220 10% 70%;
    --accent: 11 100% 59%;
    --accent-foreground: 0 0% 100%;
    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 0 0% 98%;
    --border: 220 15% 20%;
    --input: 220 15% 20%;
    --ring: 11 100% 59%;
    --radius: 0.625rem;

    /* Custom theme colors */
    --bg-primary: #0B0F17;
    --bg-secondary: #141B2A;
    --accent-orange: #FF4D2E;
    --text-primary: #FFFFFF;
    --text-secondary: #A9B3C7;
    --tennis-green: rgba(74, 222, 128, 0.22);
    --court-blue: rgba(59, 130, 246, 0.22);
    --basketball-orange: rgba(251, 146, 60, 0.22);
  }

  html.theme-royal {
    /* Theme 2: Royal Gold */
    --background: 45 30% 8%;
    --foreground: 45 30% 95%;
    --card: 45 25% 12%;
    --card-foreground: 45 30% 95%;
    --popover: 45 25% 12%;
    --popover-foreground: 45 30% 95%;
    --primary: 45 100% 50%;
    --primary-foreground: 45 30% 8%;
    --secondary: 45 20% 18%;
    --secondary-foreground: 45 30% 95%;
    --muted: 45 15% 22%;
    --muted-foreground: 45 20% 70%;
    --accent: 45 100% 50%;
    --accent-foreground: 45 30% 8%;
    --border: 45 15% 22%;
    --input: 45 15% 22%;
    --ring: 45 100% 50%;

    --bg-primary: #1A1610;
    --bg-secondary: #242018;
    --accent-orange: #FFD700;
    --text-primary: #FFF8E7;
    --text-secondary: #C9B896;
  }

  html.theme-forest {
    /* Theme 3: Forest Green */
    --background: 150 30% 6%;
    --foreground: 150 20% 95%;
    --card: 150 25% 10%;
    --card-foreground: 150 20% 95%;
    --popover: 150 25% 10%;
    --popover-foreground: 150 20% 95%;
    --primary: 150 80% 45%;
    --primary-foreground: 0 0% 100%;
    --secondary: 150 20% 14%;
    --secondary-foreground: 150 20% 95%;
    --muted: 150 15% 18%;
    --muted-foreground: 150 15% 70%;
    --accent: 150 80% 45%;
    --accent-foreground: 0 0% 100%;
    --border: 150 15% 18%;
    --input: 150 15% 18%;
    --ring: 150 80% 45%;

    --bg-primary: #0A1510;
    --bg-secondary: #111F18;
    --accent-orange: #22C55E;
    --text-primary: #F0FDF4;
    --text-secondary: #86EFAC;
  }
}

@layer base {
  * {
    @apply border-border;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    @apply bg-[var(--bg-primary)] text-[var(--text-primary)] antialiased;
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.95;
  }
}

@layer components {
  .eyebrow {
    @apply text-xs font-semibold uppercase tracking-[0.14em] text-[var(--accent-orange)];
    font-family: 'Inter', sans-serif;
  }

  .section-title {
    @apply text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-tight;
    color: var(--text-primary);
  }

  .section-subtitle {
    @apply text-base md:text-lg font-normal;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .card-sport {
    @apply relative overflow-hidden rounded-[22px] transition-all duration-300;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
  }

  .card-sport:hover {
    transform: translateY(-8px);
  }

  .btn-primary {
    @apply inline-flex items-center justify-center px-6 py-3 rounded-full font-semibold text-sm transition-all duration-300;
    background-color: var(--accent-orange);
    color: white;
  }

  .btn-primary:hover {
    transform: scale(1.05);
    filter: brightness(1.1);
  }

  .btn-secondary {
    @apply inline-flex items-center justify-center px-6 py-3 rounded-full font-semibold text-sm transition-all duration-300 border;
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--text-primary);
    background: transparent;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .gradient-overlay {
    background: linear-gradient(to right, rgba(11, 15, 23, 0.85) 0%, rgba(11, 15, 23, 0.4) 60%, rgba(11, 15, 23, 0.2) 100%);
  }

  .grain-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.04;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  }

  .sport-card-overlay-green::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(74, 222, 128, 0.18);
    pointer-events: none;
  }

  .sport-card-overlay-blue::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(59, 130, 246, 0.18);
    pointer-events: none;
  }

  .sport-card-overlay-orange::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(251, 146, 60, 0.18);
    pointer-events: none;
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent-orange) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  .animate-pulse-slow {
    animation: pulse 4s ease-in-out infinite;
  }

  .animate-bounce-slow {
    animation: bounce 3s ease-in-out infinite;
  }
}

@keyframes float {

  0%,
  100% {
    transform: translateY(0px);
  }

  50% {
    transform: translateY(-20px);
  }
}

@keyframes pulse {

  0%,
  100% {
    opacity: 1;
  }

  50% {
    opacity: 0.7;
  }
}

@keyframes bounce {

  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-10px);
  }
}

/* Scrollbar styling */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: var(--bg-primary);
}

::-webkit-scrollbar-thumb {
  background: var(--bg-secondary);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--accent-orange);
}

/* Selection styling */
::selection {
  background: var(--accent-orange);
  color: white;
}