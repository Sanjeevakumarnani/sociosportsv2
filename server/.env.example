# Backend Environment Variables (for local development)
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
# For local development (SQLite)
# DATABASE_URL="file:./dev.db"

# For production (PostgreSQL) - this will be auto-set by Render
DATABASE_URL="file:./dev.db"

# Security
JWT_SECRET=local_dev_jwt_secret_change_in_production
BCRYPT_SALT_ROUNDS=10

# Email Service (Optional - for inquiries/bookings)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
